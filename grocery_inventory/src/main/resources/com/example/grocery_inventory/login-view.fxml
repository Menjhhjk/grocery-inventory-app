<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="300.0" prefWidth="400.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.grocery_inventory.controller.LoginController">
    <children>
        <VBox alignment="CENTER" spacing="15.0"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="40.0" left="60.0" right="60.0" top="40.0"/>
            </padding>
            <children>
                <Label text="Grocery Inventory" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Label text="Please log in to continue" style="-fx-text-fill: #7f8c8d;"/>
                <TextField fx:id="usernameField" maxWidth="280.0" promptText="Username"/>
                <PasswordField fx:id="passwordField" maxWidth="280.0" promptText="Password" onAction="#onLogin"/>
                <Button defaultButton="true" minWidth="280.0" onAction="#onLogin" text="Log In"
                        style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                <Label fx:id="errorLabel" textFill="#e74c3c" wrapText="true"/>
            </children>
        </VBox>
    </children>
</AnchorPane>
